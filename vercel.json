{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/stiri/fetch",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/intreruperi/refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/newsletter/digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/sesizari/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/streaks/at-risk",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/slow-pages",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "src/app/api/ai/classify/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/ai/improve/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/stiri/fetch/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/intreruperi/refresh/route.ts": {
      "maxDuration": 180
    },
    "src/app/api/intreruperi/buildings/warm/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/intreruperi/buildings/route.ts": {
      "maxDuration": 30
    },
    "src/app/intreruperi/[id]/page.tsx": {
      "maxDuration": 30
    },
    "src/app/api/newsletter/digest/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/sesizari/reminders/route.ts": {
      "maxDuration": 60
    }
  }
}
